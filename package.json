{
  "name": "misulgom-youtube-analyzer",
  "version": "1.0.0",
  "description": "YouTube 주제 분석기 - 채널 수집, 키워드 분석, 유사도 비교, 갭 추천",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "vite",
    "build": "vite build",
    "electron:dev": "npm run build && node electron/launch.cjs",
    "electron:build": "npm run build && electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@gradio/client": "^2.1.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.4.0",
    "cors": "^2.8.5",
    "electron-store": "^10.0.0",
    "express": "^4.21.0",
    "google-auth-library": "^10.6.1",
    "multer": "^1.4.5-lts.1",
    "sql.js": "^1.11.0",
    "wavesurfer.js": "^7.12.4",
    "youtube-transcript": "^1.2.1",
    "youtube-transcript-plus": "^1.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.9",
    "nodemon": "^3.1.14",
    "png-to-ico": "^3.0.1",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.yadam.youtube-automation",
    "productName": "미슬곰 유튜브 분석 프로그램",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "server",
        "to": "server-bundle",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts",
        "to": "scripts-bundle",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "data",
        "to": "data",
        "filter": [
          "yadam.db"
        ]
      },
      {
        "from": "data/speaker-samples",
        "to": "speaker-samples",
        "filter": [
          "**/*.wav"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "미슬곰 유튜브 분석 프로그램",
      "deleteAppDataOnUninstall": true,
      "include": "electron/installer.nsh"
    },
    "asar": true,
    "asarUnpack": [
      "**/better-sqlite3/**",
      "**/*.node"
    ]
  }
}
